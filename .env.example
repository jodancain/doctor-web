# MySQL Database Connection
DATABASE_URL=mysql://root:your-password@localhost:3306/goutcare

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key

# Cookie secure:
# - 部署在 HTTPS 时建议 true
# - 非 HTTPS 环境设置为 false
COOKIE_SECURE=true

# Server Port
PORT=3000

# Logging
LOG_LEVEL=info

# Gemini API Key (for AI clinical decision support)
GEMINI_API_KEY=your-gemini-api-key
