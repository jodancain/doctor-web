# 复制为 .env 后填写（不要提交 .env 到版本库）
# --- 腾讯云开发 CloudBase（服务端读写数据库，与小程序共用同一环境）---
CLOUDBASE_ENV_ID=
CLOUDBASE_SECRET_ID=
CLOUDBASE_SECRET_KEY=

# --- 医生端 JWT ---
JWT_SECRET=

# --- Cookie：HTTPS 部署建议 true；仅 HTTP 且反向代理未透传协议时可改为 false ---
COOKIE_SECURE=true

# --- 宿主机映射端口（docker-compose 使用，见 docker-compose.yml 的 HOST_PORT）---
HOST_PORT=3000

# --- 与 docker-compose 一致：容器内监听端口（一般保持 3000）---
PORT=3000

# --- 可选：构建镜像时注入 Gemini（医生端 AI 聊天页）；不填则该功能不可用 ---
# GEMINI_API_KEY=

# --- 日志 ---
LOG_LEVEL=info
