# ============================================================
# 痛风管家 GoutCare — 后端环境变量配置模板
# 复制为 .env 并填入实际值
# ============================================================

# -------------------- 必须配置 --------------------

# MongoDB 连接地址
MONGO_URI=mongodb://admin:your_password@localhost:27017/goutcare?authSource=admin

# JWT 签名密钥（至少 32 位随机字符串）
# 可用命令生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# 微信小程序凭据（微信公众平台 → 开发管理 → 开发设置）
WX_APPID=wx88328469a06c102e
WX_SECRET=

# 医生注册授权码（注册时需输入此码才能注册为医生角色）
DOCTOR_REGISTER_CODE=18736

# -------------------- AI 服务（腾讯元器） --------------------

# 腾讯元器智能体 ID（在元器控制台获取）
YUANQI_APP_ID=2034157411355818752

# 腾讯元器 API Key（元器控制台 → 发布 → API 接入 → 复制 Token）
YUANQI_APP_KEY=

# -------------------- AI Provider 框架 --------------------

# 默认 AI 提供商（yuanqi / claude / openai）
AI_DEFAULT_PROVIDER=yuanqi

# Claude API Key（预留，启用时填入）
# CLAUDE_API_KEY=

# OpenAI API Key（预留，启用时填入）
# OPENAI_API_KEY=

# -------------------- Open API（外部 AI 接入） --------------------

# 是否启用 Open API（true/false）
OPEN_API_ENABLED=false

# -------------------- 可选配置 --------------------

# 服务端口（默认 3000）
PORT=3000

# 公网基础地址（用于图片上传返回的 URL 前缀）
APP_BASE_URL=https://yundongyl.cn

# CORS 白名单（多个逗号分隔，留空允许所有来源）
CORS_ORIGINS=https://yundongyl.cn

# Cookie Secure 标志（HTTPS 环境设为 true）
COOKIE_SECURE=true

# 日志级别
LOG_LEVEL=info
