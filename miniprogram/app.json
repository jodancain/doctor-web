{
  "pages": [
    "pages/home/index",
    "pages/auth/index",
    "pages/health-info/index",
    "pages/medical-folder/index",
    "pages/health-info/init",
    "pages/health-info/detail",
    "pages/account/index"
  ],
  "subpackages": [
    {
      "root": "packages/consult",
      "pages": [
        "index",
        "chat/index",
        "ai-chat/index",
        "doctor-messages/index",
        "doctor-client/index",
        "patient-detail/index"
      ]
    },
    {
      "root": "packages/records",
      "pages": [
        "ua-record/index",
        "ua-record/history/index",
        "attack-record/index",
        "water-record/index",
        "exercise-record/index",
        "medication-reminder/index",
        "questionnaire/detail/index"
      ]
    },
    {
      "root": "packages/resources",
      "pages": [
        "dashboard/index",
        "food-library/index",
        "article/index"
      ]
    }
  ],
  "window": {
    "backgroundColor": "#F6F8FA",
    "backgroundTextStyle": "light",
    "navigationBarBackgroundColor": "#ffffff",
    "navigationBarTitleText": "痛风慢病管理",
    "navigationBarTextStyle": "black"
  },
  "tabBar": {
    "color": "#9CA3AF",
    "selectedColor": "#4F46E5",
    "backgroundColor": "#ffffff",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/home/index",
        "text": "工作台",
        "iconPath": "images/tabs/home.png",
        "selectedIconPath": "images/tabs/home-active.png"
      },
      {
        "pagePath": "pages/health-info/index",
        "text": "健康档案",
        "iconPath": "images/tabs/book.png",
        "selectedIconPath": "images/tabs/book-active.png"
      },
      {
        "pagePath": "pages/account/index",
        "text": "个人中心",
        "iconPath": "images/tabs/user.png",
        "selectedIconPath": "images/tabs/user-active.png"
      }
    ]
  },
  "sitemapLocation": "sitemap.json",
  "style": "v2",
  "lazyCodeLoading": "requiredComponents",
  "preloadRule": {
    "pages/home/index": {
      "network": "all",
      "packages": ["packages/records"]
    }
  }
}
