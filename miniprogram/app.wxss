@import "./styles/reset.wxss";
@import "./styles/var.wxss";
@import "./styles/mixin.wxss";

page {
  background: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei',
    sans-serif;
  color: var(--text-main);
  font-size: 28rpx;
  line-height: 1.5;
}

.page-padding {
  padding: 32rpx 32rpx 64rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 32rpx;
}

/* 卡片样式 */
.card {
  background: var(--bg-color-card);
  border-radius: var(--radius-card);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
}

.card-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
  margin: 32rpx 0 16rpx;
  display: flex;
  align-items: center;
}

/* 输入框样式 */
.input-group {
  margin-bottom: 24rpx;
}

.input-label {
  font-size: 26rpx;
  margin-bottom: 12rpx;
  color: var(--text-secondary);
}

input,
textarea,
picker {
  background: #F9FAFB;
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-input);
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-main);
  transition: border-color 0.2s;
}

input:focus,
textarea:focus {
  border-color: var(--color-primary);
}

textarea {
  min-height: 160rpx;
  width: 100%;
}

/* 按钮样式 */
.button-primary {
  width: 100% !important;
  padding: 24rpx;
  background: var(--color-primary-gradient);
  color: #ffffff;
  text-align: center;
  border-radius: var(--radius-button);
  font-size: 30rpx;
  font-weight: 500;
  margin-top: 24rpx;
  box-shadow: 0 8rpx 16rpx rgba(79, 70, 229, 0.2);
}

.button-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.button-ghost {
  width: 100% !important;
  padding: 24rpx;
  border-radius: var(--radius-button);
  border: 2rpx solid var(--color-primary);
  text-align: center;
  font-size: 30rpx;
  color: var(--color-primary);
  background: transparent;
  margin-top: 24rpx;
}

.button-ghost:active {
  background: var(--color-primary-bg);
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
}

.tag.primary {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.tag.success {
  background: rgba(52, 211, 153, 0.1);
  color: var(--color-success);
}

.tag.warning {
  background: rgba(251, 191, 36, 0.1);
  color: var(--color-warning);
}

.tag.danger {
  background: rgba(239, 68, 68, 0.1);
  color: var(--color-danger);
}

/* 列表通用样式 */
.list-item {
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.list-item:last-child {
  border-bottom: none;
}

.empty-state {
  padding: 64rpx 0;
  text-align: center;
  color: var(--text-placeholder);
  font-size: 26rpx;
}

