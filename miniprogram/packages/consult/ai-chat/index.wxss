.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #FFFFFF;
  overflow: hidden;
}

.chat-list {
  flex: 1;
  height: 0;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.padding-top {
  height: 40rpx;
}

.scroll-bottom {
  height: 40rpx;
  transition: height 0.2s ease-out;
}

.msg-item {
  display: flex;
  margin-bottom: 40rpx;
  align-items: flex-start;
  width: 100%;
}

.msg-item.left {
  flex-direction: row;
}

.msg-item.right {
  flex-direction: row-reverse;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ai-avatar {
  background-color: transparent;
  color: #4F46E5;
  font-size: 64rpx;
  margin-right: 16rpx;
}

.user-avatar {
  background-color: #4F46E5;
  color: #FFFFFF;
  font-size: 28rpx;
  margin-left: 16rpx;
}

.msg-content {
  position: relative;
}

.msg-item.left .msg-content {
  background-color: transparent;
  color: #334155;
  padding: 12rpx 0;
  max-width: 85%;
}

.msg-item.right .msg-content {
  background-color: #4F46E5;
  color: #FFFFFF;
  border-radius: 20rpx;
  border-top-right-radius: 4rpx;
  padding: 20rpx 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(79, 70, 229, 0.15);
  max-width: 75%;
}

.msg-text {
  font-size: 32rpx;
  line-height: 1.7;
  word-wrap: break-word;
}

/* Typing Animation */
.typing {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 80rpx;
  box-sizing: border-box;
}

.typing-dot {
  font-size: 40rpx;
  line-height: 1;
  animation: typing 1.4s infinite;
  opacity: 0;
}

.typing-dot:nth-child(1) { animation-delay: 0s; }
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing {
  0% { opacity: 0; transform: translateY(0); }
  50% { opacity: 1; transform: translateY(-4rpx); }
  100% { opacity: 0; transform: translateY(0); }
}

/* Input Bar */
.input-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background-color: #FFFFFF;
  border-top: 1rpx solid #F1F5F9;
  position: absolute;
  left: 0;
  right: 0;
  z-index: 100;
  transition: bottom 0.2s ease-out, padding-bottom 0.2s ease-out;
}

.msg-input {
  flex: 1;
  height: 80rpx;
  background-color: #F1F5F9;
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 24rpx;
  width: 120rpx !important;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  border-radius: 36rpx;
  background-color: #E2E8F0;
  color: #94A3B8;
  font-size: 28rpx;
  font-weight: 500;
}

.send-btn.active {
  background-color: #4F46E5;
  color: #FFFFFF;
}