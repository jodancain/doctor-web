@import "../../../app.wxss";

.inbox-page {
  padding: 24rpx;
  background: var(--bg-color);
  min-height: 100vh;
}

.header {
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-main);
}

.inbox-list {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.inbox-item {
  display: flex;
  padding: 24rpx 32rpx;
  align-items: center;
  background: #ffffff;
  transition: background 0.2s;
}

.inbox-item:active {
  background: #F9FAFB;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E0F2FE, #BAE6FD);
  color: var(--color-info);
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.content-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  overflow: hidden;
}

.top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
}

.time {
  font-size: 22rpx;
  color: var(--text-placeholder);
}

.bottom-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.message {
  font-size: 26rpx;
  color: var(--text-secondary);
  flex: 1;
  padding-right: 16rpx;
}

.badge {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: var(--color-danger);
  color: #ffffff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
