@import "../../app.wxss";

.consult-page {
  padding: 24rpx;
  background: var(--bg-color);
  min-height: 100vh;
}

.hero {
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.doctor-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.doctor-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: var(--bg-color-card);
  border-radius: var(--radius-card);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.1s, box-shadow 0.1s;
}

.doctor-card:active {
  transform: scale(0.99);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E0F2FE, #BAE6FD);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 40rpx;
  color: var(--color-info);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
}

.tag {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(79, 70, 229, 0.1);
  color: var(--color-secondary);
  font-size: 20rpx;
  font-weight: 500;
}

.desc {
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1.4;
}

.ghost {
  padding: 0 32rpx !important;
  height: 64rpx !important;
  line-height: 62rpx !important;
  border-radius: 999rpx;
  border: 2rpx solid var(--color-primary) !important;
  color: var(--color-primary) !important;
  background: transparent !important;
  font-size: 26rpx !important;
  margin: 0 !important;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ghost:active {
  background: var(--color-primary-bg) !important;
}

.empty {
  margin-top: 120rpx;
  text-align: center;
  color: var(--text-placeholder);
  padding: 0 40rpx;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: var(--text-secondary);
}

.empty-desc {
  font-size: 24rpx;
}
