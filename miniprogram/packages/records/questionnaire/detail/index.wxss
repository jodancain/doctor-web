.container { padding: 30rpx; padding-bottom: 180rpx; background: #f8fafc; min-height: 100vh; box-sizing: border-box; }
.header { margin-bottom: 40rpx; background: #fff; padding: 40rpx 30rpx; border-radius: 20rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02); }
.title { font-size: 40rpx; font-weight: bold; color: #1e293b; text-align: center; }
.desc { font-size: 28rpx; color: #64748b; margin-top: 20rpx; text-align: center; line-height: 1.5; }
.question-item { background: #fff; border-radius: 20rpx; padding: 40rpx 30rpx; margin-bottom: 30rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02); }
.q-title { font-size: 32rpx; font-weight: 500; color: #334155; margin-bottom: 30rpx; line-height: 1.5; }
.required { color: #ef4444; margin-right: 8rpx; }
.option { display: flex; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid #f1f5f9; }
.option:last-child { border-bottom: none; padding-bottom: 0; }
.opt-text { font-size: 30rpx; color: #475569; margin-left: 16rpx; flex: 1; }
.textarea { width: 100%; height: 240rpx; background: #f8fafc; border-radius: 12rpx; padding: 24rpx; box-sizing: border-box; font-size: 30rpx; color: #334155; }
.rating-group { padding: 20rpx 0; }
.rating-hint { text-align: center; font-size: 24rpx; color: #94a3b8; margin-top: 20rpx; }
.footer { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 24rpx 40rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05); z-index: 100; }
.submit-btn { background: #4f46e5; color: #fff; border-radius: 16rpx; font-weight: 500; font-size: 32rpx; height: 88rpx; line-height: 88rpx; width: 100%; }
.loading { text-align: center; padding: 100rpx; color: #94a3b8; font-size: 28rpx; }
