.page-container {
  min-height: 100vh;
  background-color: #F6F8FA;
  padding: 32rpx;
  box-sizing: border-box;
  padding-bottom: 120rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #111827;
  display: block;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 仪表盘卡片 */
.dashboard-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
  margin-bottom: 48rpx;
}

.value-display {
  display: flex;
  align-items: baseline;
  margin-bottom: 24rpx;
}

.value {
  font-size: 96rpx;
  font-weight: 700;
  color: #0f766e;
  line-height: 1;
  margin-right: 12rpx;
  font-family: 'DIN Alternate', sans-serif;
}

.unit {
  font-size: 32rpx;
  color: #6B7280;
}

.status-chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  margin-bottom: 48rpx;
}

.status-chip.normal {
  background: #ECFDF5;
  color: #059669;
}

.status-chip.high {
  background: #FFFBEB;
  color: #D97706;
}

.status-chip.critical {
  background: #FEF2F2;
  color: #DC2626;
}

.status-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.slider-container {
  width: 100%;
  padding: 0 16rpx;
  box-sizing: border-box;
}

.scale-labels {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
  margin-bottom: 16rpx;
  padding: 0 10rpx;
}

.color-bar {
  height: 8rpx;
  width: 100%;
  border-radius: 4rpx;
  display: flex;
  overflow: hidden;
  margin-top: 16rpx;
}

.bar-segment {
  height: 100%;
}

.bar-segment.normal {
  width: 45%;
  background: #10B981;
}

.bar-segment.high {
  width: 15%;
  background: #F59E0B;
}

.bar-segment.critical {
  width: 40%;
  background: #EF4444;
}

/* 日期选择 */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 24rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.02);
  margin-bottom: 48rpx;
}

.picker-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-left {
  display: flex;
  align-items: center;
}

.picker-left .icon {
  font-size: 36rpx;
  margin-right: 24rpx;
  color: #6B7280;
}

.picker-value {
  font-size: 32rpx;
  color: #111827;
  font-weight: 500;
}

.arrow {
  color: #D1D5DB;
  font-size: 32rpx;
}

/* 图表区域 */
.chart-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.02);
}

.chart-section .section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.action-link {
  font-size: 26rpx;
  color: #0f766e;
}

.chart-container {
  height: 300rpx;
  width: 100%;
}

.trend-chart {
  width: 100%;
  height: 100%;
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.save-btn {
  background: #10B981;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  height: 96rpx;
  line-height: 96rpx;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.2);
}

.save-btn:active {
  opacity: 0.9;
}
