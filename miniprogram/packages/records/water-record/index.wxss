@import "../../../app.wxss";

.water-page {
  min-height: 100vh;
  background-color: #F6F8FA;
  padding-bottom: 40rpx;
}

/* 顶部标题 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F0;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 36rpx;
  color: #111827;
  font-weight: 300;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #111827;
}

.header-placeholder {
  width: 64rpx;
}

/* 进度圆环 */
.progress-section {
  padding: 60rpx 32rpx;
  display: flex;
  justify-content: center;
  background: #FFFFFF;
  margin-bottom: 24rpx;
}

.progress-wrapper {
  position: relative;
  width: 420rpx;
  height: 420rpx;
}

.progress-canvas {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.progress-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 10;
}

.water-icons {
  display: flex;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.water-icon {
  font-size: 48rpx;
  display: inline-block;
}

.current-amount {
  font-size: 72rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.2;
  margin-top: 8rpx;
}

.unit {
  font-size: 28rpx;
  color: #6B7280;
  margin-top: 8rpx;
}

.target-text {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 16rpx;
}

/* 快捷记录 */
.quick-record-section {
  padding: 40rpx 32rpx;
  background: #FFFFFF;
  margin-top: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 32rpx;
}

.quick-options {
  display: flex;
  gap: 24rpx;
  justify-content: space-between;
}

.quick-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 20rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  border: 2rpx solid #E5E7EB;
  transition: all 0.2s;
  min-height: 180rpx;
}

.quick-item:active {
  background: #F3F4F6;
  transform: scale(0.98);
}

.quick-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.quick-name {
  font-size: 26rpx;
  color: #374151;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.quick-amount {
  font-size: 22rpx;
  color: #3B82F6;
  font-weight: 600;
}

/* 自定义输入记录 */
.custom-record-section {
  display: flex;
  align-items: center;
  margin-top: 32rpx;
  gap: 24rpx;
}

.custom-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F9FAFB;
  border: 1rpx solid #E5E7EB;
  border-radius: 16rpx;
  padding: 0 32rpx;
  height: 88rpx;
}

.custom-input {
  flex: 1;
  font-size: 30rpx;
  color: #111827;
  height: 100%;
}

.custom-placeholder {
  color: #9CA3AF;
  font-size: 30rpx;
}

.custom-unit {
  font-size: 28rpx;
  color: #6B7280;
  margin-left: 16rpx;
}

.custom-btn {
  width: 140rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #E5E7EB;
  color: #9CA3AF;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.custom-btn.active {
  background: #3B82F6;
  color: #FFFFFF;
}

.custom-btn.active:active {
  background: #2563EB;
  transform: scale(0.95);
}

/* 今日明细 */
.detail-section {
  padding: 40rpx 32rpx;
  background: #FFFFFF;
  margin-top: 24rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid #F0F0F0;
  gap: 20rpx;
}

.record-icon {
  font-size: 48rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F9FAFB;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.record-info {
  flex: 1;
}

.record-type {
  font-size: 28rpx;
  color: #111827;
  font-weight: 500;
}

.record-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.record-amount {
  font-size: 28rpx;
  color: #3B82F6;
  font-weight: 600;
}

.record-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.empty-records {
  text-align: center;
  padding: 80rpx 0;
  color: #9CA3AF;
  font-size: 28rpx;
}
