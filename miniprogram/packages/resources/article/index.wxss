.container {
  display: flex;
  flex-direction: column;
  background-color: #F6F8FA;
  min-height: 100vh;
  padding-bottom: 120rpx; /* Leave space for bottom bar */
}

.cover-image {
  width: 100%;
  height: 400rpx;
  background-color: #E5E7EB;
  position: relative;
}

.cover-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.content-wrapper {
  background-color: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  margin-top: -30rpx;
  position: relative;
  z-index: 10;
  padding: 40rpx 32rpx;
  flex: 1;
}

.header {
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.4;
  margin-bottom: 24rpx;
}

.meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  font-size: 24rpx;
  color: #6B7280;
}

.category-tag {
  background-color: #E0E7FF;
  color: #4F46E5;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.time {
  flex: 1;
}

.stats {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.divider {
  height: 1rpx;
  background-color: #F3F4F6;
  margin: 30rpx 0;
}

.article-body {
  font-size: 32rpx;
  color: #374151;
  line-height: 1.8;
  padding-bottom: 40rpx;
}

.article-body p {
  margin-bottom: 24rpx;
}

.article-body strong {
  color: #111827;
  font-weight: 600;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #FFFFFF;
  border-top: 1rpx solid #E5E7EB;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 50;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #4B5563;
  font-size: 22rpx;
  padding: 10rpx 40rpx;
}

.action-btn .icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

/* Loading State */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  color: #9CA3AF;
  font-size: 28rpx;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #F3F4F6;
  border-top-color: #4F46E5;
  border-radius: 50%;
  margin-bottom: 24rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.related-section {
  margin-top: 40rpx;
  border-top: 1rpx solid #E5E7EB;
  padding-top: 40rpx;
}

.related-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 24rpx;
}

.related-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.related-card {
  background-color: #F9FAFB;
  padding: 24rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.related-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
}

.related-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #9CA3AF;
}

.related-meta .tag {
  background-color: #E5E7EB;
  color: #4B5563;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}