@import "../../../app.wxss";

.diet-page {
  min-height: 100vh;
  background-color: #F6F8FA;
  padding-bottom: 120rpx;
}

/* 顶部标题栏 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F0;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 36rpx;
  color: #111827;
  font-weight: 300;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #111827;
}

.header-placeholder {
  width: 64rpx;
}

/* 日期选择 */
.date-section {
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F0;
}

.date-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
  gap: 12rpx;
}

.date-icon {
  font-size: 32rpx;
}

.date-text {
  font-size: 28rpx;
  color: #111827;
  font-weight: 500;
}

.date-arrow {
  font-size: 20rpx;
  color: #9CA3AF;
}

/* 分类筛选 */
.category-section {
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F0;
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  padding: 20rpx 32rpx;
  gap: 20rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #6B7280;
  background: #F9FAFB;
  border-radius: 20rpx;
  white-space: nowrap;
  transition: all 0.2s;
}

.category-item.active {
  color: #FFFFFF;
  background: #4F46E5;
  font-weight: 500;
}

/* 食物列表 */
.food-list-section {
  padding: 24rpx 32rpx;
}

.food-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid #F0F0F0;
}

.food-info {
  flex: 1;
}

.food-name {
  font-size: 30rpx;
  color: #111827;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.food-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
}

.food-category {
  color: #6B7280;
}

.food-sep {
  color: #D1D5DB;
}

.food-purine {
  font-weight: 500;
}

.food-action {
  margin-left: 20rpx;
}

.delete-btn {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #EF4444;
  background: #FEE2E2;
  border-radius: 12rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  color: #9CA3AF;
  font-size: 28rpx;
  text-align: center;
}

.empty-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #D1D5DB;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  right: 32rpx;
  bottom: 32rpx;
  width: 112rpx;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4F46E5, #7C3AED);
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(79, 70, 229, 0.3);
  z-index: 100;
}

.add-icon {
  font-size: 56rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

/* 添加弹窗 */
.add-modal {
  padding: 48rpx 40rpx 40rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #111827;
  letter-spacing: 1rpx;
}

.close-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  color: #9CA3AF;
  line-height: 1;
  font-weight: 300;
}

.close-btn:active {
  color: #6B7280;
}

/* 分类选择 */
.modal-category-section {
  margin-bottom: 40rpx;
}

.category-title {
  font-size: 30rpx;
  color: #374151;
  margin-bottom: 24rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.category-options {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.category-option {
  padding: 18rpx 32rpx;
  font-size: 28rpx;
  color: #6B7280;
  background: #F9FAFB;
  border: 2rpx solid #E5E7EB;
  border-radius: 24rpx;
  min-width: 120rpx;
  text-align: center;
  transition: all 0.2s;
}

.category-option.active {
  color: #4F46E5;
  background: #EEF2FF;
  border-color: #4F46E5;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(79, 70, 229, 0.15);
}

/* 搜索框 */
.search-section {
  margin-bottom: 40rpx;
}

.search-input {
  width: 100%;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  color: #111827;
  background: #F9FAFB;
  border: 2rpx solid #E5E7EB;
  border-radius: 20rpx;
  min-height: 96rpx;
  box-sizing: border-box;
}

.search-input:focus {
  border-color: #4F46E5;
  background: #FFFFFF;
}

.search-placeholder {
  color: #9CA3AF;
  font-size: 30rpx;
}

/* 弹窗食物列表 */
.modal-food-list {
  flex: 1;
  overflow-y: auto;
  max-height: 600rpx;
}

.modal-food-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
  border: 1rpx solid #E5E7EB;
  transition: all 0.2s;
}

.modal-food-item:active {
  background: #F3F4F6;
  transform: scale(0.98);
}

.modal-food-name {
  font-size: 30rpx;
  color: #111827;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.modal-food-badge {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  border-radius: 16rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.empty-search {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 80rpx 0;
  color: #9CA3AF;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 自定义食物添加区域 */
.custom-food-actions {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-top: 32rpx;
  width: 100%;
}

/* 基础按钮样式 */
.custom-btn {
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.custom-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}

/* 绿色：低嘌呤 */
.custom-btn.low {
  background-color: #D1FAE5;
  color: #059669;
  border: 1rpx solid #34D399;
}

/* 黄色：中嘌呤 */
.custom-btn.medium {
  background-color: #FEF3C7;
  color: #D97706;
  border: 1rpx solid #FBBF24;
}

/* 红色：高嘌呤 */
.custom-btn.high {
  background-color: #FEE2E2;
  color: #DC2626;
  border: 1rpx solid #F87171;
}
