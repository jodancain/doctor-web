@import "../../app.wxss";

.account-page {
  padding: 32rpx;
  background: var(--bg-color);
  min-height: 100vh;
}

.header {
  margin-bottom: 32rpx;
  padding: 0 8rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.card {
  margin-top: 32rpx;
  background: var(--bg-color-card);
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.user-card {
  display: flex;
  align-items: center;
  gap: 32rpx;
  background: #FFFFFF;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E0F2FE, #D9F99D);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  font-weight: 700;
  color: #0F172A;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.1);
}

.meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.role-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  background: #F3F4F6;
  color: var(--text-secondary);
  font-size: 22rpx;
  font-weight: 500;
  width: fit-content;
}

.role-badge.doctor {
  background: rgba(91, 142, 241, 0.1);
  color: var(--color-primary);
}

.user-card .ghost {
  margin: 0 !important;
  padding: 0 32rpx !important;
  height: 64rpx !important;
  line-height: 62rpx !important;
  font-size: 26rpx !important;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 32rpx;
}

.field {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  margin-bottom: 16rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
  font-weight: 600;
}

.input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  color: var(--text-main);
  background: #F9FAFB;
  transition: all 0.2s;
}

.input:focus {
  border-color: var(--color-primary);
  background: #ffffff;
  box-shadow: 0 0 0 4rpx rgba(91, 142, 241, 0.1);
}

.primary {
  width: 100% !important;
  height: 96rpx !important;
  line-height: 96rpx !important;
  background: var(--color-primary-gradient);
  color: #fff;
  border-radius: 20rpx;
  padding: 0;
  font-weight: 600;
  font-size: 32rpx;
  margin-top: 40rpx;
  box-shadow: 0 8rpx 20rpx rgba(79, 70, 229, 0.2);
}

.primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.ghost {
  border: 2rpx solid var(--border-color) !important;
  background: #fff !important;
  color: var(--text-main) !important;
  border-radius: 16rpx;
  font-weight: 600;
}

.ghost:active {
  background: #F9FAFB !important;
}

.danger-card {
  border: 2rpx solid rgba(239, 68, 68, 0.1);
  background: #FEF2F2;
}

.danger-card .section-title {
  color: #B91C1C;
}

.danger-card .desc {
  color: #991B1B;
  font-size: 26rpx;
  margin-bottom: 32rpx;
  line-height: 1.5;
  opacity: 0.8;
}

.danger {
  width: 100% !important;
  height: 96rpx !important;
  line-height: 96rpx !important;
  background: #EF4444;
  color: #fff;
  border-radius: 20rpx;
  padding: 0;
  font-weight: 600;
  font-size: 32rpx;
  box-shadow: 0 8rpx 20rpx rgba(239, 68, 68, 0.2);
}

.danger:active {
  transform: scale(0.98);
  opacity: 0.9;
}
