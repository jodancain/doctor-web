@import "../../app.wxss";

.auth-page {
  min-height: 100vh;
  padding: 48rpx 40rpx;
  background: var(--bg-color);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center; /* 垂直居中 */
}

.nav-bar {
  display: none; /* 移除顶部多余的占位 */
}

.hero {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.brand-dot {
  background: var(--color-primary);
  color: #fff;
  border-radius: 16rpx;
  padding: 10rpx 20rpx;
  font-weight: 700;
  font-size: 26rpx;
  box-shadow: 0 4rpx 12rpx rgba(91, 142, 241, 0.3);
}

.brand-name {
  font-size: 36rpx;
  color: var(--text-main);
  font-weight: 800;
}

.hero-title {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: 1rpx;
}

.hero-subtitle {
  font-size: 30rpx;
  color: var(--text-secondary);
  opacity: 0.8;
}

.card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.tab-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  background: #F3F4F6;
  border-radius: 20rpx;
  padding: 8rpx;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.tab-item {
  text-align: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  color: var(--text-secondary);
  font-weight: 600;
  font-size: 30rpx;
  transition: all 0.2s ease;
}

.tab-item.active {
  background: #FFFFFF;
  color: var(--color-primary);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.form-section {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.input-block {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.label {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 600;
  margin-left: 8rpx;
}

.field {
  width: 100%;
  height: 96rpx;
  padding: 0 32rpx;
  border-radius: 24rpx;
  background: #F9FAFB;
  border: 2rpx solid transparent;
  font-size: 30rpx;
  color: var(--text-main);
  box-sizing: border-box;
  transition: all 0.2s;
}

.field:focus {
  border-color: var(--color-primary);
  background: #FFFFFF;
  box-shadow: 0 0 0 6rpx rgba(91, 142, 241, 0.1);
}

.register-extra {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  padding-top: 16rpx;
  border-top: 2rpx dashed #E5E7EB;
}

.radio-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.radio-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: #F9FAFB;
  border: 2rpx solid transparent;
  color: var(--text-secondary);
  font-weight: 500;
  transition: all 0.2s;
}

.radio-pill.checked {
  background: rgba(91, 142, 241, 0.1);
  color: var(--color-primary);
  border-color: var(--color-primary);
}

.inline-field {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.ghost {
  background: #FFFFFF !important;
  color: var(--color-primary) !important;
  border-radius: 20rpx;
  padding: 0 32rpx !important;
  height: 96rpx !important;
  line-height: 92rpx !important;
  font-size: 28rpx !important;
  border: 2rpx solid var(--color-primary) !important;
  margin: 0 !important;
  flex-shrink: 0;
}

.field-tip {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
  margin-left: 8rpx;
}

.primary-btn {
  width: 100% !important;
  height: 104rpx !important;
  line-height: 104rpx !important;
  padding: 0;
  border-radius: 24rpx;
  background: var(--color-primary-gradient);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(79, 70, 229, 0.25);
  margin-top: 16rpx;
  transition: transform 0.1s;
}

.primary-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.card-tip {
  background: rgba(52, 211, 153, 0.1);
  color: #059669;
  padding: 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  line-height: 1.6;
  border: 2rpx solid rgba(52, 211, 153, 0.2);
  text-align: center;
}
