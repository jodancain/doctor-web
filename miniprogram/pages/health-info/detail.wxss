.detail-page {
  min-height: 100vh;
  background-color: #F6F8FA;
  padding: 32rpx;
  padding-top: 100rpx; /* 为操作栏留空 */
}

.action-bar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 88rpx;
  background: #FFFFFF;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  z-index: 100;
  box-sizing: border-box;
}

.edit-link, .save-btn {
  color: #10B981;
  font-size: 30rpx;
  font-weight: 600;
}

.cancel-btn {
  color: #6B7280;
  font-size: 30rpx;
}

.card-container {
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.form-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-row {
  display: flex;
  gap: 24rpx;
}

.half {
  flex: 1;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  background: #F9FAFB;
  border: 2rpx solid #F3F4F6;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: #1F2937;
  height: auto;
  min-height: 40rpx;
}

.input.readonly {
  background: transparent;
  border-color: transparent;
  padding: 0;
  color: #111827;
  font-weight: 500;
}

.divider {
  height: 2rpx;
  background: #F3F4F6;
  margin: 40rpx 0;
}

/* 性别单选 */
.gender-radio {
  display: flex;
  gap: 24rpx;
}

.radio-opt {
  flex: 1;
  background: #F9FAFB;
  padding: 20rpx;
  text-align: center;
  border-radius: 16rpx;
  color: #4B5563;
  border: 2rpx solid transparent;
}

.radio-opt.active {
  background: #ECFDF5;
  color: #059669;
  border-color: #10B981;
  font-weight: 600;
}

/* 标签样式 */
.tags-wrapper {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.tag-chip {
  background: #FEE2E2;
  color: #B91C1C;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid #FECACA;
}

.delete-tag {
  margin-left: 12rpx;
  font-size: 32rpx;
  line-height: 1;
}

.add-tag-row {
  display: flex;
  gap: 16rpx;
}

.tag-input {
  flex: 1;
  background: #F9FAFB;
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.add-btn {
  background: #10B981;
  color: white;
  padding: 0 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: 600;
}

/* 文本域 */
.textarea {
  width: 100%;
  background: #F9FAFB;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  line-height: 1.6;
  box-sizing: border-box;
  min-height: 300rpx;
}

.textarea.readonly {
  background: transparent;
  padding: 0;
}
