.knowledge-page {
  min-height: 100vh;
  background-color: #F6F8FA;
  padding: 32rpx;
  padding-bottom: 80rpx;
}

/* 分类筛选 */
.category-section {
  margin-bottom: 32rpx;
}

.category-scroll {
  white-space: nowrap;
  width: 100%;
}

.category-list {
  display: inline-flex;
  gap: 20rpx;
  padding: 0 4rpx;
}

.category-btn {
  padding: 16rpx 36rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #374151;
  white-space: nowrap;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  font-weight: 500;
  min-height: 64rpx;
  display: flex;
  align-items: center;
}

.category-btn.active {
  background: #0f766e;
  color: #FFFFFF;
  border-color: #0f766e;
  font-weight: 600;
}

/* 热门推荐 */
.hot-section {
  margin-bottom: 56rpx;
}

.hot-card {
  background: linear-gradient(135deg, #0f766e, #14b8a6);
  border-radius: 28rpx;
  padding: 48rpx 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 118, 110, 0.25);
}

.hot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.hot-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
}

.read-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.clock-icon {
  font-size: 26rpx;
}

.hot-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 20rpx;
  line-height: 1.5;
  letter-spacing: 0.5rpx;
}

.hot-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.95);
  line-height: 1.7;
}

/* 最新文章 */
.article-section {
  margin-top: 56rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #374151;
  margin-bottom: 32rpx;
  letter-spacing: 0.5rpx;
}

.article-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.article-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.article-header {
  margin-bottom: 24rpx;
}

.article-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  line-height: 1.6;
  letter-spacing: 0.3rpx;
}

.article-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}

.category-tag {
  background: #0f766e;
  color: #FFFFFF;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 14rpx;
  font-weight: 500;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #9CA3AF;
}

.views-icon {
  font-size: 26rpx;
}

.views-count {
  margin-right: 20rpx;
  font-size: 26rpx;
}

.read-time-text {
  color: #9CA3AF;
  font-size: 26rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #9CA3AF;
  font-size: 30rpx;
}
