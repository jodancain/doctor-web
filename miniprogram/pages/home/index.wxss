@import "../../app.wxss";

.home-page {
  padding: 24rpx 24rpx 80rpx;
  background: var(--bg-color);
  min-height: 100vh;
}

/* 修改顶部卡片样式 */
.hero-card {
  background: linear-gradient(135deg, #4F46E5 0%, #3B82F6 100%);
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(59, 130, 246, 0.2);
  color: #fff;
}

.user-header {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: bold;
  color: #4F46E5;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
}

.risk-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 99rpx;
  font-weight: 600;
}

.risk-tag.safe {
  background: rgba(16, 185, 129, 0.2);
  color: #D1FAE5;
  border: 1px solid rgba(16, 185, 129, 0.4);
}

.risk-tag.warning {
  background: rgba(245, 158, 11, 0.2);
  color: #FEF3C7;
  border: 1px solid rgba(245, 158, 11, 0.4);
}

.ua-info {
  font-size: 28rpx;
  opacity: 0.9;
}

.ua-value {
  font-size: 32rpx;
  font-weight: bold;
}

/* 核心功能区域 - 保持一行4个，8个就是两行 */
.feature-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32rpx 24rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.feature-icon {
  width: 104rpx;
  height: 104rpx;
  border-radius: 32rpx;
  display: grid;
  place-items: center;
  font-size: 48rpx;
  transition: opacity 0.2s;
}

.feature-item:active .feature-icon {
  opacity: 0.8;
}

.feature-title {
  font-size: 26rpx;
  color: var(--text-main);
  font-weight: 500;
}

/* 待办事项列表样式 */
.todo-card {
  padding: 32rpx;
  border-radius: 32rpx;
  background: #fff;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.todo-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.todo-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F8FAFC;
  border-radius: 20rpx;
  gap: 24rpx;
}

.todo-icon {
  font-size: 48rpx;
}

.todo-content {
  flex: 1;
}

.todo-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 4rpx;
}

.todo-desc {
  font-size: 24rpx;
  color: #64748B;
}

.mini-btn {
  font-size: 24rpx !important;
  padding: 8rpx 24rpx !important;
  height: auto !important;
  border-radius: 99rpx;
  background: var(--color-primary-gradient);
  color: #ffffff;
}

/* 资讯轮播样式 */
.news-card {
  padding: 32rpx;
  border-radius: 32rpx;
  background: #fff;
  margin-bottom: 24rpx;
}

.news-swiper {
  height: 160rpx;
}

.news-item {
  padding: 24rpx;
  background: #F0FDF4;
  border-radius: 20rpx;
  height: 100%;
  box-sizing: border-box;
}

.news-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #166534;
  margin-bottom: 12rpx;
}

.news-desc {
  font-size: 24rpx;
  color: #15803D;
  opacity: 0.8;
}