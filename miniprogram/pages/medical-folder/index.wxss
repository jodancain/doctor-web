.folder-page {
  min-height: 100vh;
  background-color: #F6F8FA;
  padding: 32rpx;
  padding-bottom: 60rpx;
}

/* 1. 健康画像卡片 */
.profile-card {
  background: linear-gradient(135deg, #FFFFFF, #F0FDFA);
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(16, 185, 129, 0.08);
  margin-bottom: 48rpx;
  position: relative;
  overflow: hidden;
}

.profile-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar-box {
  position: relative;
  margin-right: 32rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: #E0F2FE;
  color: #0369A1;
  border-radius: 50%;
  font-size: 48rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.gender-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #3B82F6;
  color: white;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid white;
}

.gender-badge.female {
  background: #EC4899;
}

.profile-info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.name {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  margin-right: 16rpx;
}

.risk-tag {
  background: #DCFCE7;
  color: #15803D;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.meta-row {
  font-size: 26rpx;
  color: #6B7280;
  display: flex;
  align-items: center;
}

.divider {
  margin: 0 16rpx;
  color: #E5E7EB;
}

.edit-icon {
  padding: 16rpx;
  color: #9CA3AF;
  font-size: 36rpx;
}

/* 统计指标 */
.stats-grid {
  display: flex;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-divider {
  width: 2rpx;
  background: #E5E7EB;
  margin: 10rpx 0;
}

.stat-label {
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
  display: block;
}

.stat-value-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  margin-right: 8rpx;
}

.stat-unit {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* 2. 模块列表 */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 24rpx;
  margin-left: 8rpx;
}

.module-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.module-card {
  background: #FFFFFF;
  padding: 32rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
  transition: all 0.2s;
}

.module-card:active {
  transform: scale(0.98);
  background: #F9FAFB;
}

.module-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.module-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: #1F2937;
}

.arrow {
  color: #D1D5DB;
  font-size: 28rpx;
}

.footer-tip {
  text-align: center;
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 40rpx;
}

